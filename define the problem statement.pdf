{% extends 'base.html' %}
{% set active_page = 'login' %}

{% block content %}
<div class="login-page-container">
    <div class="login-card glass">
        <div class="login-header">
            <div class="logo-icon-large">
                <i class="fa-solid fa-key"></i>
            </div>
            <h2>Password Recovery</h2>
            <p>Recover your credentials via email validation</p>
        </div>

        {% if error %}
        <div class="alert-box alert-error">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span>{{ error }}</span>
        </div>
        {% endif %}

        {% if success %}
        <div class="alert-box alert-success">
            <i class="fa-solid fa-circle-check"></i>
            <span>{{ success }}</span>
        </div>
        {% endif %}

        <!-- STAGE 1: ENTER EMAIL -->
        {% if stage == 'email' %}
        <form action="/forgot-password" method="POST" class="login-form">
            <input type="hidden" name="step" value="send_otp">
            <div class="form-group">
                <label for="email"><i class="fa-solid fa-envelope"></i> Registered Email Address</label>
                <input type="email" id="email" name="email" placeholder="e.g. meteo@risingwaters.com" required>
            </div>
            <button type="submit" class="btn btn-primary btn-block">
                <span>Send OTP Code</span>
                <i class="fa-solid fa-paper-plane icon-right"></i>
            </button>
        </form>
        <div class="back-to-login">
            <a href="/login"><i class="fa-solid fa-arrow-left-long"></i> Back to Login</a>
        </div>
        {% endif %}

        <!-- STAGE 2: ENTER OTP -->
        {% if stage == 'otp' %}
        <form action="/forgot-password" method="POST" class="login-form">
            <input type="hidden" name="step" value="verify_otp">
            <input type="hidden" name="email" value="{{ email }}">
            
            <div class="otp-notif-box">
                <p>An OTP code has been dispatched. Since this is running in a local environment, the code has been written to the console/server logs.</p>
                <div class="console-preview-box">
                    <span>Generated Code:</span>
                    <strong class="otp-highlight">{{ active_otp }}</strong>
                </div>
            </div>

            <div class="form-group">
                <label for="otp"><i class="fa-solid fa-shield-halved"></i> 6-Digit Verification Code</label>
                <input type="text" id="otp" name="otp" pattern="\d{6}" maxlength="6" placeholder="e.g. 123456" style="letter-spacing: 4px; text-align: center; font-size: 18px; font-weight: bold;" required autofocus>
            </div>
            <button type="submit" class="btn btn-primary btn-block">
                <span>Verify Code</span>
                <i class="fa-solid fa-shield-check icon-right"></i>
            </button>
        </form>
        <div class="back-to-login">
            <a href="/forgot-password"><i class="fa-solid fa-arrow-left-long"></i> Back</a>
        </div>
        {% endif %}

        <!-- STAGE 3: RESET PASSWORD -->
        {% if stage == 'reset' %}
        <form action="/forgot-password" method="POST" class="login-form">
            <input type="hidden" name="step" value="reset_password">
            <input type="hidden" name="email" value="{{ email }}">
            
            <div class="form-group">
                <label for="password"><i class="fa-solid fa-lock"></i> New Password</label>
                <input type="password" id="password" name="password" placeholder="••••••••" required autofocus>
            </div>

            <div class="form-group">
                <label for="confirm_password"><i class="fa-solid fa-lock"></i> Confirm New Password</label>
                <input type="password" id="confirm_password" name="confirm_password" placeholder="••••••••" required>
            </div>

            <button type="submit" class="btn btn-primary btn-block">
                <span>Save Password</span>
                <i class="fa-solid fa-floppy-disk icon-right"></i>
            </button>
        </form>
        {% endif %}
    </div>
</div>

<style>
.login-page-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - var(--header-height) - 100px);
    padding: 20px;
}

.login-card {
    width: 100%;
    max-width: 440px;
    padding: 35px 30px;
    border-radius: var(--border-radius-lg);
    background: var(--color-card-bg);
    border: 1px solid var(--color-card-border);
    box-shadow: 0 12px 30px var(--color-shadow);
}

.login-header {
    text-align: center;
    margin-bottom: 25px;
}

.logo-icon-large {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: rgba(37, 99, 235, 0.1);
    color: var(--color-primary);
    font-size: 26px;
    margin-bottom: 15px;
}

.login-header h2 {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 700;
    color: var(--color-text-main);
    margin: 0 0 6px 0;
}

.login-header p {
    font-size: 14px;
    color: var(--color-text-muted);
    margin: 0;
}

.login-form .form-group {
    margin-bottom: 20px;
}

.login-form label {
    display: block;
    font-size: 13.5px;
    font-weight: 500;
    color: var(--color-text-main);
    margin-bottom: 8px;
}

.login-form label i {
    margin-right: 5px;
    color: var(--color-primary);
    opacity: 0.8;
}

.login-form input {
    width: 100%;
    padding: 12px 16px;
    font-size: 14.5px;
    border-radius: var(--border-radius-md);
    border: 1px solid rgba(226, 232, 240, 0.8);
    background: var(--color-input-bg);
    color: var(--color-text-main);
    transition: all 0.2s ease;
    box-sizing: border-box;
}

.login-form input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
}

.back-to-login {
    text-align: center;
    margin-top: 20px;
}

.back-to-login a {
    font-size: 13.5px;
    color: var(--color-text-muted);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
}

.back-to-login a:hover {
    color: var(--color-primary);
}

.back-to-login a i {
    margin-right: 5px;
}

.otp-notif-box {
    background: rgba(37, 99, 235, 0.05);
    border: 1px solid rgba(37, 99, 235, 0.15);
    padding: 15px;
    border-radius: var(--border-radius-md);
    margin-bottom: 20px;
    font-size: 12.5px;
    color: var(--color-text-main);
}

.otp-notif-box p {
    margin: 0 0 10px 0;
}

.console-preview-box {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(15, 23, 42, 0.05);
    padding: 8px 12px;
    border-radius: 6px;
}

.otp-highlight {
    font-size: 16px;
    color: #059669;
    font-family: monospace;
    letter-spacing: 1px;
}

.alert-box {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    border-radius: var(--border-radius-md);
    margin-bottom: 20px;
    font-size: 13.5px;
}

.alert-error {
    background: rgba(239, 68, 68, 0.1);
    color: #b91c1c;
    border: 1px solid rgba(239, 68, 68, 0.2);
}

.alert-success {
    background: rgba(16, 185, 129, 0.1);
    color: #047857;
    border: 1px solid rgba(16, 185, 129, 0.2);
}

.alert-box i {
    margin-right: 10px;
    font-size: 16px;
}
</style>
{% endblock %}
